{
  "extractor": {
    "base-directory": "~/gallery-dl",
    "cookies": "$HOME/.cache/gallery-dl/cookies.txt",
    "patreon": {
      "base-directory": "/mnt/home/angelo/gallery-dl",
      "directory": [
        "{category}",
        "{creator[vanity]}"
      ],
      "filename": "{title} [{id:>010}].{extension}"
    },
    "pixiv": {
      "artwork": {
        "directory": [
          "{category}",
          "artworks",
          "{user['id']:>08}"
        ]
      },
      "favorite": {
        "directory": [
          "pixiv",
          "bookmarks",
          "{user['id']:>08}"
        ]
      },
      "filename": "{id:>010}_p{num:>02}.{extension}"
    }
  }
}
