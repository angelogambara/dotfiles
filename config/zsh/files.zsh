# ==============================
# File Operations
# ==============================

setopt AUTO_CD
setopt INTERACTIVE_COMMENTS

# ~: Documents and Downloads aliases
alias Documents='cd ~/Documents'
alias Downloads='cd ~/Downloads'

# Documents: art, bio, dev aliases
alias Artworks='cd ~/Documents/Artworks'
alias Diary='cd ~/Documents/Diary'
alias Repos='cd ~/Documents/Repos'
alias Sketches='cd ~/Documents/Sketches'

# Downloads: YouTube aliases
alias YouTube='cd ~/Downloads/yt-dlp/youtube'
alias WL='cd ~/Downloads/yt-dlp/youtube/WL'

# Repos: dotfiles aliases
alias bin='cd ~/Documents/Repos/dotfiles/local/bin'
alias config='cd ~/Documents/Repos/dotfiles/config'
alias dotfiles='cd ~/Documents/Repos/dotfiles'
