# ==============================
# Generic Options
# ==============================

# prompt
powerline-daemon -q
source /usr/share/powerline/bindings/zsh/powerline.zsh

# vi-mode
bindkey -v
bindkey -v '^?' backward-delete-char

# you-should-use
YSU_HARDCORE_MODE=true
YSU_IGNORED_ALIASES=(g gp ga)
YSU_MESSAGE_POSITION="after"
YSU_MODE=ALL
