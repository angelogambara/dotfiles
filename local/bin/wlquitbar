#!/bin/sh

# Licensed under ISC by Angelo Gambara, published at
# https://github.com/angelogambara/dotfiles

export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-1}
export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/1000}

swaynag -t warning -m 'Select the action you want to perform.' \
	-b 'Suspend' 'sudo zzz' -b 'Power off' 'sudo poweroff' -b 'End Session' 'swaymsg quit'
