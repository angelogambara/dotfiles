#!/bin/sh
set -e

# 1st direction: extern → local
rsync -aq --update /mnt/keys/angelo/*.kdbx* ~/gdrive/Documents/

# 2nd direction: local → extern
rsync -aq --update ~/gdrive/Documents/*.kdbx* /mnt/keys/angelo/

# 3rd direction: local ↔ remote
rclone bisync --conflict-resolve newer ~/gdrive gdrive:

# 4nd direction: local → extern
rsync -aq --update ~/gdrive/Documents/*.kdbx* /mnt/keys/angelo/

# 5st direction: extern → local
rsync -aq --update /mnt/keys/angelo/*.kdbx* ~/gdrive/Documents/
