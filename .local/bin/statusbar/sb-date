#!/bin/sh

# ########
# Helper
# ########

die() {
  echo >&2 "$1"
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1 || return 1
}

check_env() {
  # Make zsh behave more like POSIX
  emulate sh 2>/dev/null

  # Prevent root from running
  [ "$(id -u)" -eq 0 ] && die "Do not run as root"

  # Ensure environment variables are set
  [ -z "$TERMINAL" ] || [ -z "$EDITOR" ] && die "TERMINAL or EDITOR is unset"

  # Add a comment here too because I can
  deps="$TERMINAL $EDITOR awk sed cal notify-send"
  for dep in $deps; do
    command_exists "$dep" || die "$dep is not installed"
  done
}

notify() {
  notify-send --icon=office-calendar-symbolic \
    --hint=string:x-canonical-private-synchronous:"$1" "$@"
}

get_date() {
  # Source theme
  . ~/.local/bin/statusbar/themes/gruvbox-dark.sh

  # Display with theme
  echo "$theme  $(date +'%a %b %d  %H:%M') $reset"
}

# ########
# Main
# ########

# Always good
check_env

# Handle mouse clicks for the status bar (statuscmd patch for dwm)
case $BLOCK_BUTTON in
1) # Left click
  notify "This Month" "$(cal --color=always |
    sed "s|..7m|<span color='#cc241d'>|;s|..0m|</span>|")"
  ;;
2) # Middle click
  if command_exists notify-checkupdates; then
    notify-checkupdates
  fi
  ;;
3) # Right click
  "$TERMINAL" -e "$EDITOR" "$0"
  ;;
esac

# Refresh block
get_date
