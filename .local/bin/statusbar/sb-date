#!/bin/sh

# ########
# Helper
# ########

die() {
  echo >&2 "$1"
  exit 1
}

command_exists() {
  command -v "$@" >/dev/null 2>&1 || return 1
}

notify() {
  command_exists notify-send &&
    notify-send \
      -h string:x-canonical-private-synchronous:"$1" "$@"
}

# ########
# Main
# ########

# Source theme
. ~/.local/bin/statusbar/themes/gruvbox-dark.sh

# Handle mouse clicks for the status bar (statuscmd patch for dwm)
case $BLOCK_BUTTON in
1) # Left click
    notify "This Month" "$(cal --color=always |
      sed "s|..7m|<span color='$red'>|;s|..0m|</span>|")"
  ;;
2) # Middle click
  command_exists notify-checkupdates &&
    notify-checkupdates
  ;;
esac

# Display with theme
echo "$theme  $(date +'%a %b %d  %H:%M') $reset"
