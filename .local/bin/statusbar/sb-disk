#!/bin/sh

# ########
# Blocks
# ########

get_disks() {
  # Output will be in reverse order
  set --  /home  /boot  /
  LAST_PATH=/

  # Source theme
  . ~/.local/bin/statusbar/themes/gruvbox-dark.sh

  # Display with theme
  echo "$1" | while read -r icon path; do
    if percent_used=$(df -h "$path" | awk '/[0-9]/ {print $5}'); then
      if [ -n "$line" ]; then
        line="$theme $icon $percent_used $reset $line"
      else
        line="$theme $icon $percent_used $reset"
      fi
    fi

    # Print the line from within the loop as workaround
    [ "$path" = "$LAST_PATH" ] && echo "$line"
  done
}

# ########
# Main
# ########

# Refresh block
get_disks
