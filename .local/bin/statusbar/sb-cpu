#!/bin/sh

# ########
# Helper
# ########

die() {
  echo >&2 "$1"
  exit 1
}

command_exists() {
  command -v "$@" >/dev/null 2>&1 || return 1
}

# ########
# Blocks
# ########

get_cpu() {
  command_exists sensors ||
    die "Error: Command not found: sensors"

  if grep -q Intel /proc/cpuinfo; then
    temperature=$(sensors | awk '/Package id 0/ {print $4}')
  else
    temperature=$(sensors | awk '/Tctl/ {print $2}')
  fi

  # Fix sensors, then retry
  [ -z "$temperature" ] && die "Error: Couldn't get temperature"

  # Source theme
  . ~/.local/bin/statusbar/themes/gruvbox-dark.sh

  # Display with theme
  echo "$theme  $temperature $reset"
}

# ########
# Main
# ########

# Refresh block
get_cpu
