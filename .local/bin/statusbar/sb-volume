#!/bin/sh

# ########
# Helper
# ########

die() {
  echo >&2 "$1"
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1 || return 1
}

check_env() {
  # Make zsh behave more like POSIX
  emulate sh 2>/dev/null

  # Prevent root from running
  [ "$(id -u)" -eq 0 ] && die "Do not run as root"

  # Ensure environment variables are set
  [ -z "$TERMINAL" ] || [ -z "$EDITOR" ] && die "TERMINAL or EDITOR is unset"

  # Add a comment here too because I can
  deps="$TERMINAL $EDITOR grep wpctl pkill"
  for dep in $deps; do
    command_exists "$dep" || die "$dep is not installed"
  done
}

get_volume() {
  volume_sink=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)

  # Nothing that can be done
  [ -z "$volume_sink" ] && die "Error: Couldn't get the volume"

  # Source theme
  . ~/.local/bin/statusbar/themes/gruvbox-dark.sh

  # Display mute state and skip volume
  if echo "$volume_sink" | grep -q MUTED; then
    echo "$theme  $reset"
    exit
  fi

  volume_frac=$(echo "$volume_sink" | cut -d' ' -f2)
  volume=$(echo "$volume_frac * 100 / 1" | bc)

  if [ "$volume" -le 15 ]; then
    icon="" # 0-15
  elif [ "$volume" -le 40 ]; then
    icon="" # 15-40
  else
    icon="" # 40-100
  fi

  # Display with theme
  echo "$theme $icon ${volume}% $reset"
}

# ########
# Main
# ########

# Always good
check_env

# Handle mouse clicks for the status bar (statuscmd patch for dwm)
case "$BLOCK_BUTTON" in
1) # Left click
  command_exists wiremix &&
    "$TERMINAL" -e wiremix
  ;;
2) # Middle click
  wpctl set-mute @DEFAULT_SINK@ toggle
  ;;
3) # Right click
  "$TERMINAL" -e "$EDITOR" "$0"
  ;;
4) # Scroll up
  wpctl set-volume --limit=1.0 @DEFAULT_SINK@ 5%+
  ;;
5) # Scroll down
  wpctl set-volume --limit=1.0 @DEFAULT_SINK@ 5%-
  ;;
esac

# Refresh block
get_volume
