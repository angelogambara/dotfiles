#!/bin/sh

# ########
# Helper
# ########

die() {
  echo >&2 "$1"
  exit 1
}

command_exists() {
  command -v "$@" >/dev/null 2>&1 || return 1
}

# ########
# Blocks
# ########

get_brightness() {
  brightness=$(brightnessctl -m | head -1 | cut -d"," -f4)

  # Nothing that can be done
  [ -z "$brightness" ] && die "Error: Couldn't get the brightness"

  # Source theme
  . ~/.local/bin/statusbar/themes/gruvbox-dark.sh

  # Display with theme
  echo "$theme  $brightness $reset"
}

# ########
# Main
# ########

# Exit if missing
command_exists brightnessctl ||
  die "Error: Command not found: brightnessctl"

# Handle mouse clicks for the status bar (statuscmd patch for dwm)
case "$BLOCK_BUTTON" in
4) # Scroll up
  brightnessctl set 5%+ >/dev/null
  ;;
5) # Scroll down
  brightnessctl set 5%- >/dev/null
  ;;
esac

# Refresh block
get_brightness
