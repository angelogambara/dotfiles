#!/bin/sh

# ########
# Helper
# ########

die() {
  echo >&2 "$1"
  exit 1
}

command_exists() {
  command -v "$@" >/dev/null 2>&1 || return 1
}

# ########
# Main
# ########

# Handle mouse clicks for the status bar (statuscmd patch for dwm)
case $BLOCK_BUTTON in
1) # Left click
  [ -n "$TERMINAL" ] && command_exists "$TERMINAL" ||
    die "Error: TERMINAL is unset or command is not found"

  command_exists neomutt &&
    "$TERMINAL" -e neomutt ||
    command_exists mutt &&
    "$TERMINAL" -e mutt
  ;;
2) # Middle click
  command_exists mailsync &&
    mailsync
  ;;
esac

unread=$(find "$MAIL" -path "*/INBOX/new/*" -type f 2>/dev/null | wc -l)

# Source theme
. ~/.local/bin/statusbar/themes/gruvbox-dark.sh

# Display with theme
echo "$theme @ $unread $reset"
