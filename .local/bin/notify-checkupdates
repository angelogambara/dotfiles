#!/bin/sh

# ########
# Env
# ########

# Mandatory: set your preferences
LINUX_KERNEL=linux
SUDO=sudo

# ########
# Helper
# ########

is_archlinux() {
  grep -q 'Arch Linux' /etc/os-release || return 1
}

is_voidlinux() {
  grep -q 'Void Linux' /etc/os-release || return 1
}

# test if LINUX_KERNEL is in UPDATES
contains_kernel() {
  echo "$UPDATES" |
    while read -r package; do
      if [ "$package" = "$LINUX_KERNEL" ]; then
        return 0
      fi
    done
  return 1
}

# Same for your BROWSER
contains_browser() {
  echo "$UPDATES" |
    while read -r package; do
      if [ "$package" = "$BROWSER" ]; then
        return 0
      fi
    done
  return 1
}

# test if aur/linux-keep-modules is installed
not_linux_keep_modules() {
  ! pacman -Qs | grep -q 'linux-keep-modules\|linux-preserve-modules'
}

# ########
# Blocks
# ########

# If the action is run the system will update
notify_update() {
  [ "$(dunstify --action="update,Update" --timeout=60000 "Updates: $UPDATES_COUNT" "$UPDATES")" = "update" ] || return 1

  if is_archlinux; then
    "$TERMINAL" -e sh -c "$SUDO pacman -Syu --noconfirm; yay -Sua --noconfirm; echo -n ':: Press enter to quit'; read"
    return
  fi

  if is_voidlinux; then
    "$TERMINAL" -e sh -c "$SUDO xbps-install -Syu; echo -n ':: Press enter to quit'; read"
    return
  fi
}

# If the action is run the system will reboot
notify_reboot() {
  [ "$(dunstify --action="reboot,Reboot" --timeout=60000 "Reboot the system" "aur/linux-keep-modules is not installed")" = "reboot" ] && reboot
}

# ########
# Main
# ########

if is_archlinux; then
  UPDATES="$(checkupdates --nocolor)"
elif is_voidlinux; then
  UPDATES="$(xbps-install -Mun | sed 's/-[0-9_]*$//')"
fi

UPDATES_COUNT=$(printf "%s" "$UPDATES" | wc -l)

if [ "$UPDATES_COUNT" -gt 0 ]; then
  notify_update || exit 0
  # Run only if notify_update returns true
  if is_archlinux && contains_kernel && not_linux_keep_modules; then
    notify_reboot
  fi
fi

# FIXME: $SUDO prompt is not displayed. Xorg becomes unresponsive
if command -v /usr/bin/flatpak >/dev/null; then
  # Sync with flathub
  if flatpak update --appstream >/dev/null 2>&1; then
    # Update if available
    if [ -n "$(flatpak remote-ls --updates 2>/dev/null)" ]; then
      "$TERMINAL" -e sh -c "flatpak update -y --noninteractive"
    fi
  fi
fi
