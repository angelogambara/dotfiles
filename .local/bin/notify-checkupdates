#!/bin/sh

# ########
# Env
# ########

# Mandatory: set your preferences
LINUX_KERNEL=linux
SUDO=sudo

# ########
# Helper
# ########

# test if LINUX_KERNEL is in UPDATES
contains_kernel() {
  echo "$UPDATES" |
    while read -r package; do
      if [ "$package" = "$LINUX_KERNEL" ]; then
        return 0
      fi
    done
  return 1
}

# test if aur/linux-keep-modules is installed
linux_keep_modules() {
  pacman -Qs |
    grep -q 'linux-keep-modules\|linux-preserve-modules'
}

# ########
# Blocks
# ########

# If the action is run the system will update
notify_update() {
  [ "$(dunstify --action="update,Update" --timeout=60000 "Updates: $(echo "$UPDATES" | wc -l)" "$UPDATES")" = "update" ] || return 1
  "$TERMINAL" -e sh -c "$SUDO pacman -Syu --noconfirm; yay -Sua --noconfirm; echo -n ':: Press enter to quit'; read"
}

# If the action is run the system will reboot
notify_reboot() {
  [ "$(dunstify --action="reboot,Reboot" --timeout=60000 "Reboot the system" "aur/linux-keep-modules is not installed")" = "reboot" ] && reboot
}

# ########
# Main
# ########

if UPDATES="$(checkupdates --nocolor)"; then
  notify_update || exit 0
  # Run only if notify_update returns true
  if contains_kernel && ! linux_keep_modules; then
    notify_reboot
  fi
fi
