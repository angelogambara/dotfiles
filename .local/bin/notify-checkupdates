#!/bin/sh

# ########
# Env
# ########

# Mandatory: set your preferences
LINUX_KERNEL=linux
SUDO="sudo -n"

# ########
# Helper
# ########

# Check if distribution is Arch Linux
is_archlinux() {
  grep -q 'Arch Linux' /etc/os-release || return 1
}

# Check if distribution is Void Linux
is_voidlinux() {
  grep -q 'Void Linux' /etc/os-release || return 1
}

# Check if kernel is in UPDATES
is_kernel_pending() {
  # Return 0 as soon as kernel is found
  echo "$UPDATES" |
    while read -r package; do
      if [ "$package" = "$LINUX_KERNEL" ]; then
        return 0
      fi
    done

  # No match found
  return 1
}

# Check if browser is in UPDATES
is_browser_pending() {
  browser_name=${BROWSER##*/}

  # Return 0 as soon as browser is found
  echo "$UPDATES" |
    while read -r package; do
      if [ "$package" = "$browser_name" ]; then
        return 0
      fi
    done

  # No match found
  return 1
}

# Check if aur/linux-keep-modules is not installed
not_keep_modules() {
  # Return 1 if not Arch Linux
  is_archlinux || return 1

  # Return 0 if package is not installed
  ! pacman -Qs | grep -q 'linux-keep-modules\|linux-preserve-modules'
}

# ########
# Blocks
# ########

# If the action is run the system will update
update_handler() {
  # Prompt the user for action
  if [ "$(dunstify --action="update,Update" --timeout=60000 "Updates: $UPDATES_COUNT" "$UPDATES")" != 'update' ]; then
    return 1
  fi

  # Update the system
  update && reboot_handler
}

# Update the system
update() {
  # Update Arch Linux
  if is_archlinux; then
    # Spawn a terminal so that user can watch
    "$TERMINAL" -e sh -c "$SUDO pacman -Syu --noconfirm; yay -Sua --noconfirm; echo -n ':: Press enter to quit'; read"
  fi

  # Update Void Linux
  if is_voidlinux; then
    # Spawn a terminal so that user can watch
    "$TERMINAL" -e sh -c "$SUDO xbps-install -Syu; echo -n ':: Press enter to quit'; read"
  fi
}

# If the action is run the system will reboot
reboot_handler() {
  # Return if kernel is not pending or linux-keep-modules is installed
  not_keep_modules && is_kernel_pending || return 1

  # Prompt the user for action
  if [ "$(dunstify --action="reboot,Reboot" --timeout=60000 "Reboot the system" "aur/linux-keep-modules is not installed")" != 'reboot' ]; then
    return 1
  fi

  # Reboot the system
  reboot
}

# If the action is run the system will flatup
flatup_handler() {
  # Prompt the user for action
  if [ "$(dunstify --action="flatup,Flatup" --timeout=60000 "Flatpak updates are available" "Update?")" != 'flatup' ]; then
    return 1
  fi

  # Exec flatup
  flatup
}

# Update flatpak packages
flatup() {
  # Spawn a terminal so that user can watch flatpak updating
  "$TERMINAL" -e sh -c "flatpak update --assumeyes --noninteractive"
}

# ########
# Main
# ########

# Get list of packages to update
if is_archlinux; then
  UPDATES="$(checkupdates --nocolor)"
elif is_voidlinux; then
  UPDATES="$(xbps-install -Mun | sed 's/-[0-9].*//')"
fi

# Count lines from packages list
if [ -n "$UPDATES" ]; then
  UPDATES_COUNT=$(printf "%s" "$UPDATES" | wc -l)
else
  UPDATES_COUNT=0
fi

# Update if any
if [ "$UPDATES_COUNT" -gt 0 ]; then
  update_handler
fi

# Do not run if flatpak is not installed
if command -v /usr/bin/flatpak >/dev/null 2>&1; then
  # Fetch updates from flathub
  if $SUDO flatpak update --appstream 2>/dev/null; then
    # Update only if there are updates
    if [ -n "$(flatpak remote-ls --updates)" ]; then
      flatup_handler
    fi
  fi
fi
