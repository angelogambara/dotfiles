#!/bin/sh
# shellcheck disable=SC2329

# ########
# Env
# ########

# Optional: as comment by default
DELIVERY_OPTIMIZATION=delivery-optimization@tp-x13

# Mandatory: set your preferences
LINUX_KERNEL=linux
PRIV_ESC_COMMAND=sudo

# ########
# Helper
# ########

die() {
  echo >&2 "$1"
  exit 1
}

die_notif() {
  notify-send --urgency=critical "$1" "$2"
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1 || return 1
}

nohup_wrap() {
  nohup "$1" >/dev/null 2>&1 &
}

pgrep_wrap() {
  pgrep -u "$(id -u)" -x "$1" >/dev/null 2>&1
}

# test if LINUX_KERNEL is in UPDATES
contains_kernel() {
  echo "$UPDATES" |
    while read -r package; do
      if [ "$package" = "$LINUX_KERNEL" ]; then
        return 0
      fi
    done
  return 1
}

# test if aur/linux-keep-modules is installed
linux_keep_modules() {
  pacman -Qs |
    grep -q 'linux-keep-modules\|linux-preserve-modules'
}

# ########
# Blocks
# ########

# NOTE: this function is a work in progress
# So, obviously it won't be perfect
# A new and improved concept can be found on my "garage":
# https://codeberg.org/angelogambara/scripts/src/branch/main/delivery-optimization.sh
notify_update() {
  [ "$(dunstify --action="update,Update" --timeout=60000 "Updates: $(echo "$UPDATES" | wc -l)" "$UPDATES")" = "update" ] || exit 1
  # If set, run delivery-optimization
  if [ -n "$DELIVERY_OPTIMIZATION" ]; then
    nohup "$TERMINAL"  -e journalctl -u "$DELIVERY_OPTIMIZATION" -f >/dev/null 2>&1 &
    pid=$($!)
    "$PRIV_ESC_COMMAND" systemctl start "$DELIVERY_OPTIMIZATION"
    kill "$pid"
  fi

  # The critical line that updates the system
  "$TERMINAL" -e sh -c "$PRIV_ESC_COMMAND pacman -Syu --noconfirm; yay -Sua --noconfirm; echo -n ':: Press enter to quit'; read"
}

# If the action is run the system will reboot
notify_reboot() {
  [ "$(dunstify --action="reboot,Reboot" --timeout=60000 "Reboot the system" "aur/linux-keep-modules is not installed")" = "reboot" ] && reboot
}

# ########
# Main
# ########

if UPDATES="$(checkupdates --nocolor)"; then
  if notify_update; then
    if contains_kernel && ! linux_keep_modules; then
      notify_reboot
    fi
  fi
fi
