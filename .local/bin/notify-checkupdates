#!/bin/sh

# Set your preferences
TERMINAL_EMULATOR=alacritty

notify_update() {
  action=$(dunstify --action="update,Update packages" --timeout=60000 "📦 Pending updates: $(echo "$UPDATES" | wc -l)" "$UPDATES")

  # Update packages now
  if [ "$action" = "update" ]; then
    "$TERMINAL_EMULATOR" -e sh -c "sudo pacman -Syu --noconfirm; yay -Sua --noconfirm; echo -n ':: Press enter'; read"
  else
    exit 1
  fi
}

notify_reboot() {
  action=$(dunstify --action="reboot,Reboot system" --timeout=60000 "🔄 Reboot the system" "Kernel modules get removed by default. Install aur/linux-keep-modules to fix it.\nIf you do, next time you will not need to reboot.")

  # Reboot the system now
  if [ "$action" = "reboot" ]; then
    sudo reboot
  fi
}

# only support the following kernels
contains_kernel() {
  echo "$UPDATES" |
    while read -r line; do
      case "$line" in
      'linux') return 0 ;;
      'linux-lts') return 0 ;;
      'linux-zen') return 0 ;;
      *) return 1 ;;
      esac
    done
}

# syntactical sugar wrapper
linux_keep_modules() {
  pacman -Qqs | grep -q 'linux-keep-modules'
}

# main
if UPDATES="$(checkupdates --nocolor)"; then
  notify_update
  if contains_kernel && ! linux_keep_modules; then
    notify_reboot
  fi
fi
