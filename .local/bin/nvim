#!/bin/sh

if [ "$(id -u)" -eq 0 ]; then
  echo >&2 "Error: Do not run as root"
  exit 1
fi

case "$(pwd)" in
"$HOME"|"$HOME"/*/)
  echo >&2 "Error: Do not run from $(pwd)"
  exit 1 ;;
esac

XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/"$(id -u)"}"
WAYLAND_SOCKET="$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY"

mkdir -p "$XDG_RUNTIME_DIR/nvim"

exec bwrap \
  --die-with-parent \
  --unshare-all \
  --share-net \
  --ro-bind /usr /usr \
  --ro-bind /lib /lib \
  --ro-bind /lib64 /lib64 \
  --ro-bind /bin /bin \
  --ro-bind /etc /etc \
  --proc /proc \
  --dev /dev \
  --tmpfs /tmp \
  --ro-bind /run/systemd/resolve /run/systemd/resolve \
  --ro-bind /tmp/.X11-unix /tmp/.X11-unix \
  --ro-bind "$XAUTHORITY" "$XAUTHORITY" \
  --ro-bind "$WAYLAND_SOCKET" "$WAYLAND_SOCKET" \
  --bind "$HOME/git" "$HOME/git" \
  --bind "$HOME/.config" "$HOME/.config" \
  --bind "$HOME/.config/nvim" "$HOME/.config/nvim" \
  --bind "$HOME/.local/bin" "$HOME/.local/bin" \
  --bind "$HOME/.local/share/nvim" "$HOME/.local/share/nvim" \
  --bind "$HOME/.local/share/zsh" "$HOME/.local/share/zsh" \
  --bind "$HOME/.local/state/nvim" "$HOME/.local/state/nvim" \
  --bind "$HOME/.cache/nvim" "$HOME/.cache/nvim" \
  --bind "$XDG_RUNTIME_DIR/nvim" "$XDG_RUNTIME_DIR/nvim" \
  --bind  "$(pwd)" "$(pwd)" \
  --chdir "$(pwd)" \
  --setenv DISPLAY "$DISPLAY" \
  --setenv WAYLAND_DISPLAY "$WAYLAND_DISPLAY" \
  --setenv XAUTHORITY "$XAUTHORITY" \
  --setenv XDG_RUNTIME_DIR "$XDG_RUNTIME_DIR" \
  /usr/bin/nvim "$@"
