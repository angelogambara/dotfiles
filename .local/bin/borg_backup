#!/bin/bash
# Exit on error, undefined variable, or pipe failure
set -euo pipefail

# Exclude from file definitions
EXCLUDE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/borg/excludefile"

# Ensure config directory and files exist
mkdir -p "${EXCLUDE_FILE%/*}"
touch "$EXCLUDE_FILE"

# Decrypt passphrase
export BORG_PASSCOMMAND="gpg --decrypt ${XDG_CONFIG_HOME:-$HOME/.config}/borg/passphrase.gpg"

# Name of the remote archive (hostname + timestamp)
ARCHIVE="ssh://backup/borg::{hostname}@{now:%Y-%m-%d_%H-%M}"

# Backup whatever you want to back up
sudo borg create \
  --one-file-system \
  --list \
  --exclude-from "$EXCLUDE_FILE" \
  -- "$ARCHIVE" "$@"
