#!/bin/sh

if [ -z "$XDG_RUNTIME_DIR" ]; then
  echo >&2 "XDG_RUNTIME_DIR is unset"
  exit 1
fi

XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/"$(id -u)"}"
WAYLAND_SOCKET="$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY"

mkdir -p "$XDG_RUNTIME_DIR/pulse/" "$HOME/.local/share/PrismLauncher"

bwrap \
  --die-with-parent \
  --new-session \
  --unshare-all \
  --share-net \
  --ro-bind /sys /sys \
  --ro-bind /usr /usr \
  --ro-bind /lib /lib \
  --ro-bind /lib64 /lib64 \
  --ro-bind /bin /bin \
  --ro-bind /etc /etc \
  --proc /proc \
  --dev /dev \
  --dev-bind /dev/dri /dev/dri \
  --tmpfs /tmp \
  --ro-bind /run/systemd/resolve /run/systemd/resolve \
  --ro-bind /tmp/.X11-unix /tmp/.X11-unix \
  --ro-bind "$XAUTHORITY" "$XAUTHORITY" \
  --ro-bind "$WAYLAND_SOCKET" "$WAYLAND_SOCKET" \
  --setenv DISPLAY "$DISPLAY" \
  --setenv WAYLAND_DISPLAY "$WAYLAND_DISPLAY" \
  --setenv XAUTHORITY "$XAUTHORITY" \
  --setenv XDG_RUNTIME_DIR "$XDG_RUNTIME_DIR" \
  --setenv MESA_GLTHREAD true \
  --setenv __GL_SYNC_TO_VBLANK 1 \
  --setenv vblank_mode 1 \
  --bind "$XDG_RUNTIME_DIR/pulse/" "$XDG_RUNTIME_DIR/pulse/" \
  --setenv PULSE_SERVER "unix:$XDG_RUNTIME_DIR/pulse/native" \
  --bind "$HOME/.local/share/PrismLauncher" "$HOME/.local/share/PrismLauncher" \
  /usr/bin/prismlauncher "$@"
