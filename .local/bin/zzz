#!/bin/sh

# Configuration
# undefined = inform the user and ask directly
# 0 = just lock the screen, skip confirmation notification
# 1 = immediately quit X11, no warnings (not recommended)
DESTROY_X11_SESSION=0

# ########
# Blocks
# ########

# Lock the screen
lock_screen() {
  # Return if physlock is used
  command -v physlock >/dev/null 2>&1 && return

  # User just wants to lock the screen
  if [ -n "$DESTROY_X11_SESSION" ]; then
    # The popular way to lock the screen on X11 (insecure)
    if ! pgrep -u "$USER" -x slock; then
      slock &
    else
      echo >&2 "Error: slock is already running"
      exit 1
    fi
    return
  fi

  # No one read anymore nowadays
  case "$(dunstify --action="destroy,Destroy X11 session" --timeout=60000 "Suspending on X11" "Screen locking is not supported on X11. Use middle click to quit. You can always ignore this message in the config: dismiss it or let it expire.\nMake sure to startx && exit or use a login manager because on resume, you will be dropped on the tty. Remember to save all your progress first.")" in
  "destroy")
    # Remember to destroy X11 later
    DESTROY_X11_SESSION=1
    ;;
  1)
    # Do nothing if dismiss or timed out
    exit 1
    ;;
  esac
}

# ########
# Main
# ########

lock_screen

# Avoid race conditions
sleep 1

# Read distro
. /etc/os-release

# Run suspend command
case "$ID" in
"void")
  sudo zzz
  ;;
*)
  systemctl suspend
  ;;
esac

# Kill Xorg on resume (secure)
if [ "$DESTROY_X11_SESSION" -eq 1 ]; then
  killall Xorg
fi
