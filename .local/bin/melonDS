#!/bin/sh
bwrap \
  --unshare-all \
  --new-session \
  --die-with-parent \
  --ro-bind /usr /usr \
  --ro-bind /lib /lib \
  --ro-bind /lib64 /lib64 \
  --ro-bind /bin /bin \
  --ro-bind /etc /etc \
  --dev /dev \
  --proc /proc \
  --tmpfs /tmp \
  --dir /run/user/$(id -u) \
  --bind $HOME/.config/melonDS $HOME/.config/melonDS \
  --bind $HOME/http $HOME/http \
  --ro-bind $XAUTHORITY $XAUTHORITY \
  --setenv XAUTHORITY $XAUTHORITY \
  --setenv HOME $HOME \
  --setenv XDG_RUNTIME_DIR /run/user/$(id -u) \
  --setenv DISPLAY $DISPLAY \
  --setenv WAYLAND_DISPLAY "${WAYLAND_DISPLAY:-}" \
  --ro-bind /tmp/.X11-unix /tmp/.X11-unix \
  --dev-bind /dev/dri /dev/dri \
  --dev-bind /dev/snd /dev/snd \
  --bind /run/user/$(id -u)/pulse /run/user/$(id -u)/pulse \
  --setenv PULSE_SERVER unix:/run/user/$(id -u)/pulse/native \
  melonDS
