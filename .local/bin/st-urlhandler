#!/bin/sh
# Extract URLs from stdin (st externalpipe), then open or copy via dmenu.
# Requires: dmenu, xclip, xdg-open

set -eu

# Regex for matching URLs
url_regex='(((http|https|gopher|gemini|ftp|ftps|git)://|www\.)[a-zA-Z0-9.]*[:;a-zA-Z0-9./+@$&%?$\#=_~-]*)|((magnet:\?xt=urn:btih:)[a-zA-Z0-9]*)'

# Read stdin, clean it, and extract URLs
urls="$(
    sed 's/.*│//g' |           # Remove mutt sidebar
    tr -d '\n' |               # Join lines
    grep -aEo "$url_regex" |   # Extract URLs
    uniq |                     # Remove adjacent duplicates
    sed '
        s/[.,;!?]$//;          # Strip trailing punctuation
        s/^www\./http:\/\/www\./
    '
)"

# Exit if no URLs found
[ -z "$urls" ] && exit 1

usage() {
    printf "Usage: %s [-o | -c | -h]\n" "$0"
    printf "  -o  Open URL with xdg-open\n"
    printf "  -c  Copy URL to clipboard\n"
    printf "  -h  Show this help message\n"
}

# Handle options
mode=""

while getopts "hoc" opt; do
    case "$opt" in
        h)
            usage
            exit 0
            ;;
        o)
            mode="open"
            ;;
        c)
            mode="copy"
            ;;
        *)
            printf "Invalid option: -%s\n" "$OPTARG" >&2
            usage >&2
            exit 1
            ;;
    esac
done

# Default to open if no mode specified
: "${mode:=open}"

# Select URL via dmenu
chosen="$(printf '%s\n' "$urls" | dmenu -i -p 'Select URL:' -l 10)"

[ -z "$chosen" ] && exit 0

case "$mode" in
    open)
        setsid xdg-open "$chosen" >/dev/null 2>&1 &
        ;;
    copy)
        printf '%s' "$chosen" | tr -d '\n' | xclip -selection clipboard
        ;;
esac
