#!/bin/sh

TARGET=$1; shift
POSITION="$*"

if [ -n "$WAYLAND_DISPLAY" ]; then
  COMMAND="wlr-randr"
  ON_FLAG="--on"
else
  COMMAND="xrandr"
  ON_FLAG="--auto"
fi

if $COMMAND | grep ' connected ' | grep "$TARGET"; then
  $COMMAND --output "$TARGET" --off
else
  $COMMAND --output "$TARGET" $ON_FLAG "$POSITION"
fi
